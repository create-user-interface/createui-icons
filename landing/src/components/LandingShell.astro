---
import type { Lang } from '../i18n';
import Header from './Header.astro';
import Hero from './Hero.astro';
import WeightSpectrum from './WeightSpectrum.astro';
import Problems from './Problems.astro';
import HowItWorks from './HowItWorks.astro';
import Integration from './Integration.astro';
import Explorer from './Explorer.astro';
import Performance from './Performance.astro';
import Talk from './Talk.astro';
import Faq from './Faq.astro';
import Support from './Support.astro';
import Changelog from './Changelog.astro';
import Footer from './Footer.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<Header lang={lang} />
<main>
  <Hero lang={lang} />
  <WeightSpectrum lang={lang} />
  <Problems lang={lang} />
  <HowItWorks lang={lang} />
  <Integration lang={lang} />
  <Explorer lang={lang} />
  <Performance lang={lang} />
  <Talk lang={lang} />
  <Faq lang={lang} />
  <Support lang={lang} />
  <Changelog lang={lang} />
</main>
<Footer lang={lang} />
