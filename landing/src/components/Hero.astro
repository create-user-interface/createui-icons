---
import styles from '../styles/Hero.module.css';
import { nbsp } from '../utils/nbsp';
import type { Lang } from '../i18n';
import { useT } from '../i18n';
import { CDN, VERSION, iconUrl } from '../utils/iconUrl';

interface Props { lang?: Lang }
const { lang = 'ru' } = Astro.props;
const t = useT(lang);

const DEFAULT_ICON = 'sparkles';
const DEFAULT_WEIGHT = '1.5';

const PARTICLE_ICONS = [
  'heart', 'star', 'cloud', 'moon', 'sun', 'zap', 'globe', 'code',
  'layers', 'compass', 'feather', 'anchor', 'aperture', 'box', 'coffee',
  'diamond', 'flame', 'gem', 'hexagon', 'infinity', 'wand-2', 'package',
  'puzzle', 'shapes', 'palette', 'cpu', 'database', 'key', 'mountain',
  'rocket', 'shield', 'tree-pine', 'umbrella', 'waves', 'wind',
  'leaf', 'snowflake',
];

const WEIGHTS = ['0.5', '0.75', '1', '1.25', '1.5', '1.75', '2', '2.25', '2.5', '2.75', '3'];
const ANIM_NAMES = ['heroDrift1', 'heroDrift2', 'heroDrift3', 'heroDrift4', 'heroDrift5'];

function mulberry32(seed: number) {
  let t = seed >>> 0;
  return () => {
    t = (t + 0x6D2B79F5) >>> 0;
    let x = Math.imul(t ^ (t >>> 15), t | 1);
    x ^= x + Math.imul(x ^ (x >>> 7), x | 61);
    return ((x ^ (x >>> 14)) >>> 0) / 4294967296;
  };
}

const rng = mulberry32(20260412);

function pick<T>(arr: T[]): T {
  return arr[Math.floor(rng() * arr.length)];
}

function range(min: number, max: number): number {
  return min + rng() * (max - min);
}

// Per-layer min distance is in % units of the hero box.
// Larger icons get larger radius so big ones never clump.
const LAYERS = [
  { count: 34, sizeMin: 20, sizeMax: 32, opacityMin: 0.08, opacityMax: 0.16, durationMin: 14, durationMax: 22, minDist: 6 },
  { count: 26, sizeMin: 36, sizeMax: 54, opacityMin: 0.16, opacityMax: 0.26, durationMin: 10, durationMax: 18, minDist: 9 },
  { count: 14, sizeMin: 58, sizeMax: 84, opacityMin: 0.22, opacityMax: 0.34, durationMin: 12, durationMax: 20, minDist: 13 },
] as const;



interface Particle {
  name: string;
  top: number;
  left: number;
  size: number;
  opacity: number;
  animName: string;
  duration: number;
  delay: number;
}

// Dart-throwing Poisson-disk sampling with a soft-falloff acceptance test.
// Single global point pool keeps layers from overlapping each other.
const placed: Array<{ x: number; y: number }> = [];
const particles: Particle[] = [];

const MARGIN = 2;
const MAX_ATTEMPTS_PER_POINT = 400;

for (const layer of LAYERS) {
  let made = 0;
  let attempts = 0;
  const maxAttempts = layer.count * MAX_ATTEMPTS_PER_POINT;
  while (made < layer.count && attempts < maxAttempts) {
    attempts++;
    const x = range(MARGIN, 100 - MARGIN);
    const y = range(MARGIN, 100 - MARGIN);

    let ok = true;
    for (const p of placed) {
      const dx = p.x - x;
      const dy = p.y - y;
      if (dx * dx + dy * dy < layer.minDist * layer.minDist) { ok = false; break; }
    }
    if (!ok) continue;

    placed.push({ x, y });
    particles.push({
      name: pick(PARTICLE_ICONS),
      top: y,
      left: x,
      size: range(layer.sizeMin, layer.sizeMax),
      opacity: range(layer.opacityMin, layer.opacityMax),
      animName: pick(ANIM_NAMES),
      duration: range(layer.durationMin, layer.durationMax),
      delay: -range(0, 25),
    });
    made++;
  }
}

const initialUrl = iconUrl(DEFAULT_ICON, DEFAULT_WEIGHT);
---

<section class={styles.hero}>
  <div class={styles.particles} aria-hidden="true">
    {particles.map((p) => {
      const url = iconUrl(p.name, '1.5');
      return (
        <div
          class={styles.particle}
          style={[
            `top: ${p.top.toFixed(2)}%`,
            `left: ${p.left.toFixed(2)}%`,
            `width: ${p.size.toFixed(0)}px`,
            `height: ${p.size.toFixed(0)}px`,
            `--p-opacity: ${p.opacity.toFixed(3)}`,
            `opacity: ${p.opacity.toFixed(3)}`,
            `-webkit-mask-image: url('${url}')`,
            `mask-image: url('${url}')`,
            `animation: ${p.animName} ${p.duration.toFixed(1)}s ease-in-out ${p.delay.toFixed(1)}s infinite`,
          ].join('; ')}
        />
      );
    })}
  </div>

  <div class={styles.content}>
    <div class={styles.textBlock}>
      <h1 class={styles.title}>
        <span data-i18n="hero.titleLine1">{nbsp(t.hero.titleLine1)}</span><br /><span data-i18n="hero.titleLine2">{nbsp(t.hero.titleLine2)}</span>
      </h1>
      <p class={styles.subtitle}>
        <span data-i18n="hero.subtitleLine1">{nbsp(t.hero.subtitleLine1)}</span><br />
        <span data-i18n="hero.subtitleLine2">{nbsp(t.hero.subtitleLine2)}</span>
      </p>

      <dl class={styles.stats}>
        {t.hero.stats.map((s, i) => (
          <div class={styles.stat}>
            <dt class={styles.statValue} data-i18n={`hero.stats.${i}.value`}>{s.value}</dt>
            <dd class={styles.statLabel} data-i18n={`hero.stats.${i}.label`}>{s.label}</dd>
          </div>
        ))}
      </dl>
    </div>

    <div class={styles.demo}>
      <div
        id="hero-icon-preview"
        class={styles.iconPreview}
        style={`-webkit-mask-image: url('${initialUrl}'); mask-image: url('${initialUrl}');`}
      />

      <div class={styles.sliderContainer}>
        <div class={styles.segmentedTracker} id="hero-weight-tracker">
          <div class={styles.trackerLine}></div>
          {WEIGHTS.map((w) => (
            <button 
              class={styles.trackSegment} 
              data-hero-weight={w}
              data-active={w === DEFAULT_WEIGHT ? 'true' : 'false'}
              aria-label={`Stroke weight ${w}`}
            ></button>
          ))}
        </div>
        <span id="hero-weight-label" class={styles.sliderLabel}>
          <span data-i18n="hero.weightLabel">{t.hero.weightLabel}</span>: <span data-hero-weight-value>{DEFAULT_WEIGHT}</span>
        </span>
      </div>

      <div id="hero-url-display" class={styles.urlDisplay}>
        {initialUrl}
      </div>
    </div>
  </div>

  <div style="position: absolute; width: 0; height: 0; overflow: hidden; visibility: hidden;" aria-hidden="true">
    {WEIGHTS.map(w => (
      <img src={iconUrl(DEFAULT_ICON, w)} alt="" decoding="async" loading="eager" />
    ))}
  </div>
</section>

<script is:inline define:vars={{ CDN, VERSION, DEFAULT_ICON }}>
  const tracker = document.getElementById('hero-weight-tracker');
  const iconPreview = document.getElementById('hero-icon-preview');
  const weightValueEl = document.querySelector('[data-hero-weight-value]');
  const urlDisplay = document.getElementById('hero-url-display');

  if (tracker && iconPreview && weightValueEl && urlDisplay) {
    const segments = Array.from(tracker.querySelectorAll('button[data-hero-weight]'));

    segments.forEach(segment => {
      segment.addEventListener('click', () => {
        const weight = segment.getAttribute('data-hero-weight');
        segments.forEach(seg => seg.setAttribute('data-active', 'false'));
        segment.setAttribute('data-active', 'true');

        const url = `${CDN}/${VERSION}/${DEFAULT_ICON}.svg?stroke=${weight}`;
        iconPreview.style.setProperty('-webkit-mask-image', `url('${url}')`);
        iconPreview.style.setProperty('mask-image', `url('${url}')`);
        weightValueEl.textContent = weight;
        urlDisplay.textContent = url;
      });
    });

    urlDisplay.addEventListener('click', () => {
      navigator.clipboard.writeText(urlDisplay.textContent);
      const originalText = urlDisplay.textContent;
      urlDisplay.textContent = 'COPIED!';
      setTimeout(() => {
        urlDisplay.textContent = originalText;
      }, 1500);
    });
  }
</script>
