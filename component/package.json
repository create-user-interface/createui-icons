{
  "name": "@createui-dev/icons",
  "version": "1.21.0",
  "description": "Framework-agnostic icon web component for Create UI",
  "license": "MIT",
  "homepage": "https://icons.createui.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/create-user-interface/createui-icons.git"
  },
  "bugs": "https://github.com/create-user-interface/createui-icons/issues",
  "keywords": [
    "icons",
    "icon",
    "web-component",
    "custom-element",
    "lucide",
    "svg",
    "framework-agnostic",
    "stroke-width"
  ],
  "type": "module",
  "main": "./dist/icon.js",
  "module": "./dist/icon.js",
  "types": "./dist/icon.d.ts",
  "exports": {
    ".": {
      "types": "./dist/icon.d.ts",
      "import": "./dist/icon.js"
    },
    "./types/react": {
      "types": "./dist/types-react.d.ts",
      "import": "./dist/types-react.js"
    },
    "./types/solid": {
      "types": "./dist/types-solid.d.ts",
      "import": "./dist/types-solid.js"
    }
  },
  "sideEffects": [
    "./dist/icon.js"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "sync-version": "node scripts/sync-version.mjs",
    "generate:names": "node scripts/generate-icon-names.mjs",
    "generate": "npm run sync-version && npm run generate:names",
    "prepare": "npm run sync-version",
    "prebuild": "npm run generate",
    "build": "npm run build:types && npm run build:bundle",
    "build:types": "tsc",
    "build:bundle": "esbuild src/icon.ts --bundle --format=iife --global-name=CreateUIIcons --outfile=dist/bundle/createui-icons.js --target=es2020 --minify --sourcemap",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/react": "*",
    "esbuild": "^0.28.0",
    "lucide": "^1.21.0",
    "solid-js": "*",
    "typescript": "^6.0.2"
  }
}
